{
	"name": "vova-post-grids",
	"version": "1.0.1",
	"description": "A responsive Post Grids block with flexible queries and AJAX pagination.",
	"author": "Vova Anokhin",
	"license": "GPL-2.0-or-later",
	"private": true,
	"scripts": {
		"start": "wp-scripts start --webpack-copy-php",
		"build:assets": "wp-scripts build --webpack-copy-php",
		"make-pot": "wp i18n make-pot . languages/vova-post-grids.pot --slug=vova-post-grids --domain=vova-post-grids --exclude=build,node_modules,vendor,dist && node scripts/remove-pot-creation-date.js",
		"build": "npm run build:assets && npm run make-pot",
		"export": "node scripts/export.js",
		"format": "prettier --write . --ignore-unknown",
		"format:check": "prettier --check . --ignore-unknown",
		"test:unit": "wp-scripts test-unit-js",
		"lint:js": "wp-scripts lint-js",
		"lint:css": "wp-scripts lint-style",
		"lint:php": "vendor/bin/phpcs",
		"lint:php:fix": "vendor/bin/phpcbf"
	},
	"devDependencies": {
		"@wordpress/api-fetch": "6.51.0",
		"@wordpress/block-editor": "12.22.0",
		"@wordpress/blocks": "12.31.0",
		"@wordpress/components": "27.2.0",
		"@wordpress/data": "9.24.0",
		"@wordpress/element": "5.31.0",
		"@wordpress/i18n": "4.54.0",
		"@wordpress/url": "3.55.0",
		"@wordpress/prettier-config": "3.11.0",
		"@wordpress/scripts": "27.5.0",
		"@wordpress/stylelint-config": "21.37.0",
		"ignore": "^5.3.2",
		"prettier": "npm:wp-prettier@3.0.3",
		"typescript": "5.4.5"
	}
}
